while True:

    print("\n=== SISTEMA DE PAGOS ===")
    print("1. Pagar con Tarjeta")
    print("2. Pagar con PayPal")
    print("3. Salir")

    opcion = input("Seleccione una opción: ")

    if opcion == "1":

        try:
            numero = input("Número de tarjeta (16 dígitos): ")
            fecha = input("Fecha de expiración (MM/AA): ")
            codigo = input("Código de seguridad (3 dígitos): ")
            monto = float(input("Monto a pagar: "))

            tarjeta = TarjetaCredito(numero, fecha, codigo)

            print(tarjeta.procesar_pago(monto))

        except Exception as e:
            print("Error:", e)

    elif opcion == "2":

        try:
            correo = input("Correo PayPal: ")
            saldo = float(input("Saldo disponible: "))
            monto = float(input("Monto a pagar: "))

            paypal = PayPal(correo, saldo)

            print(paypal.procesar_pago(monto))

        except Exception as e:
            print("Error:", e)

    elif opcion == "3":

        print("Programa finalizado.")
        break

    else:
        print("Opción inválida.")
